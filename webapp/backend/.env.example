# Copy to ".env" and adjust (webapp/backend/.env is gitignored).
# cp .env.example .env

SMARTEATS_DATABASE_URL=mysql+pymysql://smarteats_app:SmartEats3170App123@127.0.0.1:3306/smarteats
SMARTEATS_APP_NAME=SmartEats Control Center
SMARTEATS_ALLOWED_ORIGINS=*
SMARTEATS_HOST=0.0.0.0
SMARTEATS_PORT=8000
SMARTEATS_SESSION_SECRET_KEY=change-this-session-secret
SMARTEATS_SESSION_COOKIE_NAME=smarteats_session
SMARTEATS_SESSION_HTTPS_ONLY=false
SMARTEATS_ADMIN_USERNAME=admin
SMARTEATS_ADMIN_PASSWORD_HASH=

# --- LLM assistant (required: API key only; base URL & model have code defaults) ---
# Get a token: https://modelscope.cn/my/myaccesstoken — paste below. Never commit the real key.
SMARTEATS_OPENAI_API_KEY=

# Optional overrides (defaults are built into app/config.py for ModelScope + GLM):
# SMARTEATS_OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
# SMARTEATS_LLM_MODEL=ZhipuAI/GLM-5.1

# OpenAI instead of ModelScope (example):
# SMARTEATS_OPENAI_BASE_URL=https://api.openai.com/v1
# SMARTEATS_LLM_MODEL=gpt-4o-mini
# SMARTEATS_OPENAI_API_KEY=sk-...

# Remote DB example:
# SMARTEATS_DATABASE_URL=mysql+pymysql://smarteats_app:your_password@your_host:3306/smarteats
